      ></div>
      <div
        class="absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-gradient-to-tr from-primary-500/25 via-teal-400/20 to-cyan-400/15 blur-3xl animate-float-delayed"
      ></div>
      <div
        class="absolute left-1/3 top-1/4 h-80 w-80 rounded-full bg-gradient-to-br from-purple-400/15 via-pink-400/10 to-primary-300/10 blur-3xl animate-pulse-slow"
      ></div>
      <div
        class="absolute bottom-1/4 right-1/4 h-72 w-72 rounded-full bg-gradient-to-tl from-blue-400/15 via-primary-400/10 to-teal-400/10 blur-3xl animate-pulse-slower"
      ></div>
      <!-- Grid pattern with shimmer effect -->
      <div
        class="absolute inset-0 bg-[linear-gradient(rgba(20,184,166,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(20,184,166,0.04)_1px,transparent_1px)] bg-[size:64px_64px] animate-grid-shimmer"
      ></div>
      <!-- Subtle noise texture -->
      <div class="absolute inset-0 bg-noise opacity-[0.015] dark:opacity-[0.025]"></div>
    </div>

    <!-- Header -->
